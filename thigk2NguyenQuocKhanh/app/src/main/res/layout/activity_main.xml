<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="51dp"
        android:layout_marginBottom="32dp"
        android:text="THI GIỮA KỲ"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnFunction1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 1: Đổi tiền"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnFunction2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 2: Ca khúc cách mạng"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnFunction3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 3: Danh nhân lịch sử"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnFunction4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 4: Thông tin cá nhân"/>

</LinearLayout>